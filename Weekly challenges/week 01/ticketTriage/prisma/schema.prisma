// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite does not support native enums.
// Priority is enforced as a string at the TypeScript and API layer.
// See src/lib/types.ts for the Priority enum definition.

model Ticket {
  id          String   @id @default(cuid())
  title       String
  description String
  priority    String
  owner       String?
  createdAt   DateTime @default(now())

  @@index([priority])
}
